{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "4744391261502259212"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "serviceBusConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Service Bus connection string"
      }
    },
    "keyVaultUri": {
      "type": "string",
      "metadata": {
        "description": "Key Vault URI for the shared Key Vault"
      }
    },
    "blobStorageConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Blob Storage connection string for YouTube token storage"
      }
    },
    "appInsightsConnectionString": {
      "type": "string",
      "metadata": {
        "description": "Application Insights connection string"
      }
    },
    "acsConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Azure Communication Services connection string"
      }
    },
    "acsSender": {
      "type": "string",
      "metadata": {
        "description": "ACS sender email address"
      }
    },
    "acsRecipients": {
      "type": "string",
      "metadata": {
        "description": "ACS recipient email addresses (comma-separated)"
      }
    },
    "sharedKeyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the shared Key Vault (for role assignment)"
      }
    },
    "sharedStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the shared Storage Account (for role assignment)"
      }
    }
  },
  "variables": {
    "suffix": "[uniqueString(resourceGroup().id)]",
    "appName": "[format('stream-title-svc-{0}', variables('suffix'))]",
    "storageAccountName": "[format('strtitlesvc{0}', take(variables('suffix'), 10))]",
    "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6",
    "storageBlobDataReaderRoleId": "2a2b9908-6ea1-4ae2-8e65-a410df84e7d1"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}-plan', variables('appName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "FC1",
        "tier": "FlexConsumption"
      },
      "kind": "functionapp",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('appName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', variables('appName')))]",
        "siteConfig": {
          "appSettings": [
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "SERVICE_BUS_CONNECTION",
              "value": "[parameters('serviceBusConnectionString')]"
            },
            {
              "name": "SERVICE_BUS_TOPIC",
              "value": "stream-title"
            },
            {
              "name": "SERVICE_BUS_SUBSCRIPTION",
              "value": "stream-title-service"
            },
            {
              "name": "KEY_VAULT_URI",
              "value": "[parameters('keyVaultUri')]"
            },
            {
              "name": "BLOB_STORAGE_CONNECTION",
              "value": "[parameters('blobStorageConnectionString')]"
            },
            {
              "name": "ACS_CONNECTION_STRING",
              "value": "[parameters('acsConnectionString')]"
            },
            {
              "name": "ACS_SENDER",
              "value": "[parameters('acsSender')]"
            },
            {
              "name": "ACS_RECIPIENTS",
              "value": "[parameters('acsRecipients')]"
            },
            {
              "name": "STALENESS_THRESHOLD_SECONDS",
              "value": "90"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('appInsightsConnectionString')]"
            },
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[variables('storageAccountName')]"
            },
            {
              "name": "DEPLOYMENT_STORAGE_CONNECTION_STRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value)]"
            }
          ],
          "linuxFxVersion": "DOTNET-ISOLATED|9.0"
        },
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[format('{0}deployments', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').primaryEndpoints.blob)]",
              "authentication": {
                "type": "StorageAccountConnectionString",
                "storageAccountConnectionStringName": "DEPLOYMENT_STORAGE_CONNECTION_STRING"
              }
            }
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": 100,
            "instanceMemoryMB": 2048
          },
          "runtime": {
            "name": "dotnet-isolated",
            "version": "9.0"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', variables('appName')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('sharedKeyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('sharedKeyVaultName')), resourceId('Microsoft.Web/sites', variables('appName')), variables('keyVaultSecretsUserRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUserRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('appName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('sharedStorageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('sharedStorageAccountName')), resourceId('Microsoft.Web/sites', variables('appName')), variables('storageBlobDataReaderRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataReaderRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('appName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[variables('appName')]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2024-04-01', 'full').identity.principalId]"
    },
    "functionAppDefaultHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('appName')), '2024-04-01').defaultHostName]"
    }
  }
}